# PostgreSQL database connection string (Supabase, Neon, etc.)
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Admin dashboard password (for /admin)
ADMIN_PASSWORD="changeme"

# Secret key shared with the Raspberry Pi
# All /api/hardware/* endpoints require header: x-hardware-key: <this value>
HARDWARE_API_KEY="super-secret-raspberry-key"

# Base URL (required for Vercel deployments)
NEXTAUTH_URL="https://your-app.vercel.app"
